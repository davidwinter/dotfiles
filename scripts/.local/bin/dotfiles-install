#!/usr/bin/env bash

set -euo pipefail

DOTFILES_DIR="${DOTFILES_DIR:-$HOME/dotfiles}"
OP_AGENT_SOCKET_PATH="$HOME/.1password/agent.sock"
OP_SSH_SIGN_PATH="/usr/local/bin/op-ssh-sign"

if ! dotfiles-has-command dotfiles-has-command 2>/dev/null; then
    export PATH="$DOTFILES_DIR/scripts/.local/bin:$PATH"
fi

source "$DOTFILES_DIR/scripts/.local/lib/dotfiles-lib.sh"

mark_migrations_as_applied() {
    local state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/dotfiles/migrations"

    # Only mark migrations on fresh install (state directory doesn't exist yet)
    if [[ -d "$state_dir" ]]; then
        echo "   ℹ️  Skipping (existing installation)"
        return 0
    fi

    mkdir -p "$state_dir"

    if [[ -d "$DOTFILES_DIR/migrations" ]]; then
        for migration in "$DOTFILES_DIR/migrations"/*.sh; do
            [[ -f "$migration" ]] || continue
            local migration_file=$(basename "$migration")
            touch "$state_dir/$migration_file"
            echo "   ✅ Marked $migration_file as applied"
        done
    fi
}

echo
echo "📦 Packages:"
echo

if ! install_core_packages; then
    echo "   ⚠️  Failed to install core packages - please install them manually (e.g. git, stow, curl, jq)" >&2
    exit 1
fi

while IFS= read -r pkg; do
    if ensure_package_installed "$pkg"; then
        echo "   ✅ $pkg is installed"
    else
        echo "   ⚠️  Failed to install $pkg - please install it manually" >&2
        exit 1
    fi
done < <(get_packages_for_host)

echo
echo "🔑 1Password:"
echo

if dotfiles-is-ssh-session; then
    echo "   ℹ️  SSH session detected — skipping 1Password setup"
    echo "   ℹ️  Git signing will use the forwarded SSH agent via ssh-keygen"
else
    if ! dotfiles-is-wsl; then
        ensure_1password_agent "$OP_AGENT_SOCKET_PATH" && echo "   ✅ 1Password agent socket OK"
    fi

    ensure_1password_ssh_sign "$OP_SSH_SIGN_PATH" && echo "   ✅ 1Password op-ssh-sign helper available at $OP_SSH_SIGN_PATH"
fi

echo
echo "🔐 Git Remote:"
echo

if ensure_git_remote_ssh; then
    echo "   ✅ Git remote configured for SSH"
fi

echo
echo "📃 Dotfile configs:"
echo

while IFS= read -r config; do
    if [[ "$config" == "scripts" ]]; then
        (ensure_dotfiles_config_present "scripts" "." && echo "   ✅ scripts config enabled") || echo "   ❌ scripts config failed"
    else
        (ensure_dotfiles_config_present "$config" && echo "   ✅ $config config enabled") || echo "   ❌ $config config failed"
    fi
done < <(get_configs_for_host)

echo
echo "🐟 Fish shell:"
echo

ensure_fish_in_etc_shells && echo "   ✅ fish is listed in /etc/shells"
(ensure_fish_is_default_shell && echo "   ✅ fish is your default login shell") || echo "   ❌ Run the following to change shell:    chsh -s \"$(command -v fish)\""

echo
echo "📋 Migrations:"
echo

mark_migrations_as_applied

echo
