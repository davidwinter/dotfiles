#!/usr/bin/env bash
set -euo pipefail

DOTFILES_DIR="${DOTFILES_DIR:-$HOME/dotfiles}"

if ! dotfiles-has-command dotfiles-has-command 2>/dev/null; then
    export PATH="$DOTFILES_DIR/scripts/.local/bin:$PATH"
fi

source "$DOTFILES_DIR/scripts/.local/lib/dotfiles-lib.sh"

echo "🏥 Dotfiles Health Check"
echo

echo "📦 Packages:"
echo

echo "🔧 Core packages (toolchain):"
check_core_packages
echo

echo "🔧 User packages:"
while IFS= read -r pkg; do
    [[ -z "$pkg" ]] && continue

    if is_core_package "$pkg"; then
        echo "   ℹ️  Skipping core package: $pkg"
        continue
    fi

    if check_package_installed "$pkg"; then
        echo "   ✅ $pkg"
    else
        echo "   ❌ $pkg"
    fi
done < <(get_packages_for_host)

echo
echo "🔑 1Password:"
if dotfiles-is-ssh-session; then
    echo "   ℹ️  SSH session — 1Password not expected on this host"
else
    if check_1password_agent; then
        echo "   ✅ Agent socket"
    else
        echo "   ❌ Agent socket"
    fi

    if check_1password_ssh_sign; then
        echo "   ✅ SSH sign helper"
    else
        echo "   ❌ SSH sign helper"
    fi
fi

echo
echo "🔐 Git:"
if check_git_remote_ssh; then
    echo "   ✅ Remote uses SSH"
else
    echo "   ❌ Remote uses HTTPS"
fi

echo
echo "📃 Configurations:"

if check_dotfiles_config_present "scripts" "."; then
    echo "   ✅ scripts"
else
    echo "   ❌ scripts"
fi

while IFS= read -r config; do
    [[ "$config" == "scripts" ]] && continue

    if check_dotfiles_config_present "$config"; then
        echo "   ✅ $config"
    else
        echo "   ❌ $config"
    fi
done < <(get_configs_for_host)

echo
echo "🐟 Fish Shell:"
if check_fish_in_etc_shells; then
    echo "   ✅ Listed in /etc/shells"
else
    echo "   ❌ Not in /etc/shells"
fi

if check_fish_is_default_shell; then
    echo "   ✅ Default shell"
else
    echo "   ❌ Not default shell"
fi

echo
echo "📋 Migrations:"
if check_migrations_applied; then
    echo "   ✅ All applied"
else
    echo "   ⚠️  Pending (run: dotfiles-update)"
fi

echo
echo "💡 To fix issues, run: dotfiles-install"
